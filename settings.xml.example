<?xml version="1.0" encoding="UTF-8"?>
<!--
  OPTIONAL Maven user settings fragment: activates profile hi-wsdl-tree with hi.wsdl.tree.root.

  Default checkout: this branch tracks WSDL/XSD under wsdls/xml in Git (see wsdls/readme.txt). Run
    mvn clean verify
  with no -s flag. The POM defaults hi.wsdl.tree.root to ${project.basedir}/wsdls/xml; you can also set
  HI_WSDL_TREE_ROOT or mvn "-Dhi.wsdl.tree.root=..." without touching settings files.

  When to use this file:
  - Merge the profile into ~/.m2/settings.xml (recommended if you want a persistent non-default path and
    to keep your mirrors/servers in the same file), OR
  - Copy to a path and run: mvn -s /path/to/that/settings.xml ...
    WARNING: "mvn -s <file>" uses ONLY that file as user settings for that invocation (Maven does not merge
    with ~/.m2/settings.xml). You lose repository mirrors and <server> credentials from your global settings
    unless you duplicate them in that file. Prefer -Dhi.wsdl.tree.root or HI_WSDL_TREE_ROOT for one-off overrides.

  Copyright 2021-2026 ADHA. SPDX-License-Identifier: Apache-2.0 (same as the project).
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 https://maven.apache.org/xsd/settings-1.2.0.xsd">
    <profiles>
        <profile>
            <id>hi-wsdl-tree</id>
            <properties>
                <hi.wsdl.tree.root>./wsdls/xml</hi.wsdl.tree.root>
            </properties>
        </profile>
    </profiles>
    <activeProfiles>
        <activeProfile>hi-wsdl-tree</activeProfile>
    </activeProfiles>
</settings>
